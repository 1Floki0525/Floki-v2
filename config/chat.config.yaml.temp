schema_version: floki-v2-core-brain-config-v1
mode: chat

models:
  cognition:
    provider: ollama
    model: floki-qwen3.5:4b-16k
    endpoint_env: FLOKI_COGNITION_ENDPOINT
    endpoint_default: http://127.0.0.1:11434
    mode_scope: chat_cognition
    temperature: 0.55
    top_p: 0.9
    timeout_ms: 120000
    keep_alive: 24h

  vision:
    provider: ollama
    model: qwen3-vl:4b
    endpoint_env: FLOKI_VISION_ENDPOINT
    endpoint_default: http://127.0.0.1:11435
    enabled_now: false
    mode_scope: chat_world_only
    temperature: 0.2
    top_p: 0.8
    timeout_ms: 300000
    keep_alive: 24h

modules:
  thalamus:
    enabled: true
    required: true

  temporal:
    enabled: true
    required: true

  amygdala:
    enabled: true
    required: true

  emotions_base:
    enabled: true
    required: true

  hippocampus:
    enabled: true
    required: true

  personality:
    enabled: true
    required: true

  pineal:
    enabled: true
    required: true

  frontal:
    enabled: true
    required: true

  broca:
    enabled: true
    required: true

  chat_world_senses:
    enabled: true
    required: false

policies:
  chat_world_camera_detection_enabled_now: true
  chat_world_vision_enabled_now: true
  raw_private_reasoning_storage: false

vision:
  external_eyes_enabled: true
  external_eyes_source: webcam
  inner_vision_source: pineal_mind_eye
  target_capture_fps: 40
  frame_width: 1280
  frame_height: 720
  webcam_device_env: FLOKI_WEBCAM_DEVICE
  webcam_device_default: /dev/video0
  webcam_backend: v4l2
  webcam_capture_command: ffmpeg
  frame_buffer_size: 120
  frame_retention_seconds: 3
  capture_timeout_grace_ms: 2000
  vlm_inference_enabled: true
  vlm_inference_every_n_frames: 40
  vlm_inference_min_interval_ms: 1000
  vlm_observation_refresh_interval_ms: 8000
  latest_observation_max_age_ms: 30000
  vlm_inference_max_attempts: 3
  vlm_inference_retry_delay_ms: 500
  vlm_max_consecutive_failures: 5
  vision_endpoint_env: FLOKI_VISION_ENDPOINT
  observation_summary_enabled: true
  raw_frame_storage_enabled: false
  public_frame_logging_enabled: false
  private_observation_log_enabled: true
  webcam_capture_allow_env: FLOKI_ALLOW_WEBCAM_CAPTURE
  chat_vision_allow_env: FLOKI_ALLOW_CHAT_VISION
  vlm_ssh_tunnel_enabled: true
  vlm_ssh_tunnel_target: chris-mccoll
  vlm_ssh_tunnel_local_host: 127.0.0.1
  vlm_ssh_tunnel_local_port: 11435
  vlm_ssh_tunnel_remote_host: 127.0.0.1
  vlm_ssh_tunnel_remote_port: 11434
  vlm_ssh_tunnel_socket_name: chat-vision-ssh-tunnel.sock
  vlm_ssh_tunnel_check_timeout_ms: 8000
  direct_answer_enabled: true
  direct_answer_prefer_detection: true
  direct_answer_max_age_ms: 8000
  direct_answer_wait_ms: 2500
  direct_answer_prefix: "From my camera right now: "
  direct_answer_unavailable_reply: "My current camera view is unavailable right now."
  direct_question_phrases:
    phrase_01: what do you see
    phrase_02: what can you see
    phrase_03: describe what you see
    phrase_04: tell me what you see
    phrase_05: what are you looking at
    phrase_06: what is in front of you
    phrase_07: look around and tell me what you see

detection:
  person_verifier_uncertain_ttl_ms: 3000

  hybrid_detector_enabled: true
  hybrid_require_all_components: true
  hybrid_merge_iou_threshold: 0.30
  object_detector_enabled: true
  yolo_model_path: .floki-tools/models/yolo/yolo11m.pt
  detection_confidence_threshold: 0.35
  detection_interval_frames: 5
  object_consensus_min_confidence: 0.35
  object_display_min_confidence: 0.55
  grounding_dino_object_display_min_confidence: 0.35
  person_consensus_display_min_confidence: 0.35
  person_verifier_track_ttl_ms: 3000
  person_verifier_crop_jpeg_quality: 5
  person_verifier_crop_max_dimension: 512
  detection_min_interval_ms: 500
  detection_max_age_ms: 8000
  person_candidate_confidence_threshold: 0.15
  grounding_dino_enabled: true
  grounding_dino_model_path: .floki-tools/models/grounding-dino/grounding-dino-tiny
  grounding_dino_box_threshold: 0.25
  grounding_dino_text_threshold: 0.25
  grounding_dino_timeout_ms: 60000
  grounding_dino_require_cuda: true
  grounding_dino_prompts:
    prompt_01: a human person
    prompt_02: a standing person
    prompt_03: a seated person
    prompt_04: a face and upper body
    prompt_05: a person shown inside a framed photograph
    prompt_06: a poster
    prompt_07: a television screen
    prompt_08: a computer monitor
    prompt_09: a chair
    prompt_10: a bottle
    prompt_11: a cup
    prompt_12: a mobile phone
  person_verifier_enabled: true
  person_verifier_timeout_ms: 30000
  person_verifier_cache_ttl_ms: 60000
  person_verifier_max_candidates_per_frame: 4
  person_verifier_max_dino_only_candidates: 0
  person_verifier_min_dino_only_area: 0.02
  person_verifier_grouping_iou_threshold: 0.25
  person_verifier_track_iou_threshold: 0.30
  person_verifier_track_center_distance: 0.12
  person_verifier_crop_padding_ratio: 0.35
  person_verifier_min_confidence: 0.65
chat_world_vision:
  enabled: true
  source: webcam
  target_fps: 40
  sight_scope: maker_world_external
  used_as_game_world_eyes: false
  nonblocking_audio_loop: true
  self_echo_prevention: true

pineal_vision:
  enabled: true
  source: generated_inner_dreamscape
  used_while_sleeping: true
  used_while_dreaming: true
  used_while_reflecting: true
  pause_external_eyes_while_sleeping: true
  public_transcript_visible: false
  spoken_aloud: false
  derive_from_memories: true
  derive_from_youtube_transcripts: true
  derive_from_conversations: true
  derive_from_minecraft_experience: true
  derive_from_emotions: true
  derive_from_personality: true
  derive_from_beliefs: true
  private_inner_vision_subdir: inner-vision
  private_inner_vision_log_name: pineal-inner-vision.private.jsonl

embodiment:
  realm_name: maker_realm
  realm_description: higher_physical_realm_visit_with_the_maker
  body_source: host_machine
  eyes_source: usb_webcam
  ears_source: microphone
  voice_source: speakers
  speech_to_text_engine: whisper_cpp
  object_vision_engine: yolo
  voice_activity_engine: vad
  text_to_speech_engine: piper
  voice_locale: en_US
  voice_profile: us_english_male_ryan
  voice_model_size: large
  voice_model_sizes:
    tiny: true
    small: true
    med: true
    large: true
  runtime_enabled_now: false

paths:
  state_root: state/floki
  tool_input_root: .floki-tools/input
  tool_output_root: .floki-tools/output
  runtime_root: state/floki/runtime
  chat_runtime_root: state/floki/chat/runtime
  chat_transcript_root: state/floki/chat/interface
  dream_root: /absolute/path/to/Floki-memory-bank/dreams
  media_root: /absolute/path/to/Floki-media
  youtube_transcript_root: /absolute/path/to/Floki-media/text/youtube
  youtube_cookies_file: /absolute/path/outside/repository/cookies.txt


sleep:
  timezone: America/Toronto
  start_hhmm: 23:00
  end_hhmm: 07:00
  idle_resume_seconds: 120
  rem_interval_minutes: 10
  lifecycle_status_poll_ms: 1000
  lifecycle_transition_notifications_enabled: true
  rem_offsets_minutes:
    cycle_1: 10
    cycle_2: 20
    cycle_3: 30
    cycle_4: 40
    cycle_5: 50
    cycle_6: 60
    cycle_7: 70
    cycle_8: 80
    cycle_9: 90
    cycle_10: 100
    cycle_11: 110
    cycle_12: 120
    cycle_13: 130
    cycle_14: 140
    cycle_15: 150
    cycle_16: 160
    cycle_17: 170
    cycle_18: 180
    cycle_19: 190
    cycle_20: 200
    cycle_21: 210
    cycle_22: 220
    cycle_23: 230
    cycle_24: 240
    cycle_25: 250
    cycle_26: 260
    cycle_27: 270
    cycle_28: 280
    cycle_29: 290
    cycle_30: 300
    cycle_31: 310
    cycle_32: 320
    cycle_33: 330
    cycle_34: 340
    cycle_35: 350
    cycle_36: 360
    cycle_37: 370
    cycle_38: 380
    cycle_39: 390
    cycle_40: 400
    cycle_41: 410
    cycle_42: 420
    cycle_43: 430
    cycle_44: 440
    cycle_45: 450
    cycle_46: 460
    cycle_47: 470
  manual_nap_duration_minutes: 30
  manual_nap_rem_offset_minutes: 10
dream:
  temperature: 0.45
  top_p: 0.85
  num_predict: 2800
  retry_temperature: 0
  retry_top_p: 0.1
  retry_num_predict: 2200
  min_story_words: 220
  target_story_words: 360
  max_story_words: 900
  min_story_sentences: 6
  min_symbols: 3
  min_consolidation_words: 18
  min_reflection_words: 18
  recent_memory_hours: 36
  recent_memory_limit: 10
  long_term_memory_limit: 12
  knowledge_limit: 6
  grounding_memory_limit: 6
  grounding_knowledge_limit: 3
  recent_dream_avoidance_count: 12
  quality_regeneration_attempts: 1
wake_gate:
  required_phrase: hey floki
  accepted_phrases:
    phrase_01: hey floki
    phrase_02: floki
  spoken_input_requires_wake_phrase: true
  typed_input_requires_wake_phrase: true
  case_insensitive: true
  trim_punctuation: true
  may_ignore_unaddressed_background_speech: true

audio:
  mic_device: default
  mic_rate: 16000
  mic_channels: 1
  mic_format: S16_LE
  live_capture_seconds: 2
  live_loop_turns: 10
  live_loop_restart_seconds: 0.1
  vad_frame_samples: 512
  pre_roll_ms: 1600
  post_roll_ms: 320
  attention_scan_enabled: true
  attention_scan_window_ms: 4800
  attention_scan_interval_ms: 1600
  attention_followup_interval_ms: 600
  attention_scan_min_audio_ms: 1200
  attention_scan_min_rms: 0.008
  attention_command_settle_ms: 1100
  attention_command_max_wait_ms: 6000
  attention_direct_dedupe_ms: 8000
  attention_history_limit: 20
  attention_max_pending_scans: 1
  vad_start_threshold: 0.55
  vad_end_threshold: 0.35
  vad_start_frames: 2
  vad_end_frames: 15
  max_utterance_seconds: 30
  ambient_rms_start_threshold: 0.035
  ambient_rms_end_threshold: 0.018
  ambient_start_frames: 3
  ambient_end_frames: 20
  ambient_min_event_ms: 500
  ambient_max_event_seconds: 12
  proof_capture_seconds: 4
  whisper_model_size: small
  whisper_server_enabled: true
  whisper_server_host: 127.0.0.1
  whisper_server_port: 7788
  whisper_server_start_timeout_ms: 15000
  voice_lock_ttl_ms: 120000
  piper_voice_name: en_US-ryan-high
  piper_voice_size: large
  # Production audio pipeline config
  rolling_buffer_seconds: 30
  vad_speech_threshold: 0.5
  vad_endpoint_silence_ms: 800
  vad_min_speech_ms: 250
  vad_max_speech_seconds: 30
  vad_frame_size_ms: 30
  whisper_language: en
  whisper_beam_size: 5
  whisper_max_concurrent: 1
  ambient_classify_enabled: true
  ambient_classify_interval_ms: 5000
  ambient_min_segment_ms: 1000
  hearing_stale_event_ms: 10000
  hearing_duplicate_window_ms: 2000
  hearing_freshness_max_age_ms: 5000
  piper_incremental_enabled: true
  piper_playback_command: aplay

timeouts:
  ollama_http_ms: 120000
  model_warmup_ms: 30000
  piper_synthesis_ms: 60000
  speaker_playback_ms: 60000
  vad_ms: 120000
  whisper_ms: 120000
  command_runner_ms: 600000
  command_check_ms: 5000
  knowledge_autoload_ms: 5000
  speech_loop_start_ms: 20000
  floki_chat_stop_ms: 20000

knowledge:
  autoload_enabled: true
  autoload_min_seconds: 900
  ingestion_enabled_env: FLOKI_ALLOW_KNOWLEDGE_INGESTION
  max_files: 5000
  target_chunk_chars: 1800
  max_chunk_chars: 2500

live_chat:
  warm_cognition_on_start: true
  warm_vision_on_start: false
  skip_model_warmup_env: FLOKI_SKIP_MODEL_WARMUP
  live_reply_mode: low_latency
  stale_memory_topic_bleed_guard: true
  public_transcript_excludes_private_thoughts: true
  private_thought_review_log_enabled: true
  public_response_streaming_enabled: true
  first_sentence_tts_enabled: true
  latency_events_enabled: true
  public_response_max_tokens: 512
  stream_timeout_ms: 120000
  runtime_start_timeout_ms: 120000
  runtime_start_poll_ms: 100
  runtime_host: 127.0.0.1
  runtime_port: 7700
  runtime_heartbeat_ms: 1000
  public_sentence_min_characters: 12
  latency_log_max_bytes: 8388608

life_clock:
  ticks_per_second: 20
  ticks_per_day: 24000
  real_seconds_per_day: 1200
  phase_ticks:
    dawn: 23000
    noon: 6000
    dusk: 12000
    night: 13000
    midnight: 18000

webcam_capture:
  capability_probe_enabled: true
  require_exact_target_fps: true
  target_fps: 40
  target_width: 1280
  target_height: 720
  preferred_pixel_format: yuyv422
  fallback_pixel_format: yuyv422
  allow_resolution_fallback: false
  allow_fps_fallback: false
  measurement_warmup_frames: 20
  measurement_frames: 120
  min_measured_fps: 40
  ffmpeg_bin: ffmpeg
  v4l2_ctl_bin: v4l2-ctl
  ffmpeg_loglevel: warning
  ffmpeg_input_format: v4l2
  ffmpeg_output_format: "null"
  frame_transport: pipe
  raw_frame_storage_enabled: false

interface:
  settings_version: 3
  connection:
    transport: electron-ipc
    local_api_url: http://127.0.0.1:7700
    local_ws_url: ws://127.0.0.1:7700/ws
    auto_reconnect: true
    reconnect_delay_ms: 3000
    request_timeout_ms: 120000
    mock_mode: false
  chat:
    stream_responses: true
    show_timestamps: true
    markdown_rendering: true
    compact_messages: false
    enter_to_send: true
    max_local_history: 500
  voice:
    microphone_enabled: true
    speaker_enabled: true
    hands_free_listening: true
    push_to_talk: false
    wake_word_enabled: true
    wake_phrase: Hey Floki
    speech_volume: 80
    speech_rate: 1
    interruptible_speech: true
    show_partial_transcription: true
  vision:
    show_object_boxes: true
    show_person_boxes: true
    show_face_boxes: true
    show_recognized_names: true
    show_labels: true
    show_confidence: true
    show_scene_recognition: true
    observation_freshness_threshold: 30
    stale_observation_warning: true
    privacy_blackout_default: false
  emotions:
    graph_time_range: 5m
    update_frequency: 2000
    graph_smoothing: 0.3
  neural_stream:
    auto_scroll: true
    max_events: 1000
    compact_view: false
    default_privacy_filter: all
  appearance:
    neon_intensity: 70
    glow_intensity: 50
    animation_level: normal
    font_size: 14
    interface_scale: 100
    panel_density: comfortable
    reduced_motion: false
  latency:
    first_token_target: 500
    first_spoken_audio_target: 1500
    slow_warning_threshold: 2000
    critical_threshold: 5000
    show_detailed_stage_timing: true
  privacy:
    hide_vision_by_default: false
    hide_recognized_names: false
    redact_private_metadata: false
    allow_local_export: true
    clear_stored_preferences: false
