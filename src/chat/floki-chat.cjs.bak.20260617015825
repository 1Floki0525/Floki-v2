function printStatus(runtime) {
  const clock = makeLifeClockState({
    brain_started_at: runtime.started_at,
    current_at: nowIso()
  });

  const affect = runtime.emotionsBase.loadAffectState();
  const affectSummary = summarizeAffectForMemory(affect);
  const personalitySummary = runtime.personality.summarizePersonality(runtime.personality.loadPersonalityState());
  const identitySummary = runtime.pineal.summarizeIdentity(runtime.pineal.loadIdentityState());

  console.log(JSON.stringify({
    ok: true,
    marker: 'FLOKI_V2_CHAT_STATUS',
    session_id: runtime.session_id,
    started_at: runtime.started_at,
    minecraft_tick: clock.minecraft_tick,
    minecraft_phase: clock.phase,
    sleep_recommended: clock.sleep_recommended,
    dream_seed_recommended: clock.dream_seed_recommended,
    affect: affectSummary,
    personality_top_traits: personalitySummary.top_traits,
    identity: {
      name: identitySummary.name,
      formation_stage: identitySummary.formation_stage,
      anchor_counts: identitySummary.anchor_counts
    },
    affect_scaffold_enabled_now: true,
    reflective_emotion_enabled_now: false,
    cognition_enabled_now: true,
    broca_enabled_now: false,
    minecraft_enabled_now: false
  }, null, 2));
}

