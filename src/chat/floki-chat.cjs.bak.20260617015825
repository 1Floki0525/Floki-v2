function printRecall(runtime, queryText) {
  const recallOutput = runtime.hippocampus.recall({
    text: queryText,
    streams: ['short_term', 'episodic', 'semantic', 'autobiographical'],
    limit: 5
  });

  console.log(JSON.stringify({
    ok: true,
    marker: 'FLOKI_V2_CHAT_RECALL',
    query: queryText,
    match_count: recallOutput.payload.match_count,
    matches: recallOutput.payload.matches.map((match) => ({
      score: match.score,
      stream: match.stream,
      memory_id: match.record.id,
      summary: match.record.content.summary,
      affect: match.record.affect,
      tags: match.record.tags
    }))
  }, null, 2));
}

function startInteractiveChat() {
  const runtime = createChatRuntime();
  printIntro(runtime);

  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
    prompt: 'you> '
  });

  rl.prompt();

  rl.on('line', async (line) => {
    const text = line.trim();

    try {
      if (!text) {
        rl.prompt();
        return;
      }

      if (text === '/exit' || text === '/quit') {
        console.log('FLOKI_V2_TERMINAL_CHAT_CLOSED');
        rl.close();
        return;
      }

      if (text === '/help') {
        printIntro(runtime);
        rl.prompt();
        return;
      }

      if (text === '/status') {
        printStatus(runtime);
        rl.prompt();
        return;
      }

      if (text === '/affect') {
        printAffect(runtime);
        rl.prompt();
        return;
      }

      if (text === '/personality') {
        printPersonality(runtime);
        rl.prompt();
        return;
      }

      if (text === '/self') {
        printSelf(runtime);
        rl.prompt();
        return;
      }

      if (text.startsWith('/recall ')) {
        printRecall(runtime, text.slice('/recall '.length).trim());
        rl.prompt();
        return;
      }

      if (text === '/sleep') {
        const sleepResult = handleSleep(runtime);
        console.log(JSON.stringify({
          ok: true,
          marker: 'FLOKI_V2_CHAT_SLEEP_SEED_CREATED',
          consolidation_output_id: sleepResult.consolidation.id,
          dream_seed_id: sleepResult.dreamSeed.id,
          dream_pressure: sleepResult.dreamSeed.dream_pressure,
          affect_used: sleepResult.affectSummary,
          personality_used: sleepResult.personalitySummary,
          identity_used: sleepResult.identitySummary,
          vivid_dream_generated_now: false
        }, null, 2));
        rl.prompt();
        return;
      }

      const result = await handleUserText(runtime, text);

      console.log(JSON.stringify({
        ok: true,
        marker: 'FLOKI_V2_CHAT_SELF_UPDATE_RECORDED',
        event_id: result.event.id,
        route_targets: result.routeOutput.payload.targets,
        salience: result.salienceOutput.payload.salience,
        appraisal: result.salienceOutput.payload.appraisal,
        affect: result.affectSummary,
        memory_id: result.memoryOutput.payload.memory_id,
        personality_output_id: result.personalityOutput.id,
        identity_output_id: result.identityOutput.id,
        personality_summary: result.personalityOutput.payload.current,
        identity_summary: result.identityOutput.payload.current,
        recall_match_count: result.recallOutput.payload.match_count,
        broca_enabled_now: false,
        affect_scaffold_enabled_now: true,
    reflective_emotion_enabled_now: false,
    cognition_enabled_now: false,
        cognition: result.cognitionOutput.type === 'model_response_summary' ? result.cognitionOutput.payload.cognition : { error: result.cognitionOutput.failure && result.cognitionOutput.failure.message },
        note: 'Memory, affect, personality, identity, and qwen cognition updated. Broca speech comes next.'
      }, null, 2));
    } catch (error) {
      console.error(JSON.stringify({
        ok: false,
        marker: 'FLOKI_V2_CHAT_ERROR',
        error: error.message
      }, null, 2));
    }

    rl.prompt();
  });

  rl.on('close', () => {
    process.exit(0);
  });
}

async function runSmoke() {
  const runtime = createChatRuntime({
    session_id: newId('chatsmoke')
  });

  const result = await handleUserText(runtime, 'Smoke test: Floki should remember, learn, and form hope before Minecraft embodiment.');
  const sleepResult = handleSleep(runtime);

  console.log(JSON.stringify({
    ok: true,
    marker: 'FLOKI_V2_CHAT_SHELL_PASS',
    session_id: runtime.session_id,
    event_id: result.event.id,
    memory_id: result.memoryOutput.payload.memory_id,
    personality_output_id: result.personalityOutput.id,
    identity_output_id: result.identityOutput.id,
    salience: result.salienceOutput.payload.salience,
    affect: result.affectSummary,
    dream_seed_id: sleepResult.dreamSeed.id,
    broca_enabled_now: false,
    affect_scaffold_enabled_now: true,
    reflective_emotion_enabled_now: false,
    cognition_enabled_now: false
  }, null, 2));
}

function main() {
  if (process.argv.includes('--smoke')) {
    runSmoke().catch((error) => { console.error(JSON.stringify({ ok: false, marker: 'FLOKI_V2_CHAT_SHELL_FAIL', error: error.message }, null, 2)); process.exit(1); });
    return;
  }

  startInteractiveChat();
}

main();
