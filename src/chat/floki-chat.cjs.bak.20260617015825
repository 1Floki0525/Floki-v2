'use strict';

/**
 * Floki-v2 terminal chat shell.
 *
 * Current stage:
 * - routes user text through thalamus
 * - computes salience through amygdala
 * - updates persistent affect through emotions_base
 * - writes affect-weighted memories through hippocampus
 * - updates persistent personality
 * - updates persistent identity continuity
 *
 * Broca + qwen3.5 cognition are not wired yet, so this shell does not fake Floki's full voice.
 */

const readline = require('node:readline');

const { makeUserTextEvent } = require('../brain/brain-event-schema.cjs');
const { createThalamus } = require('../../brain/thalamus/index.cjs');
const { createHippocampus } = require('../../brain/hippocampus/index.cjs');
const { createAmygdala } = require('../../brain/amygdala/index.cjs');
const { createTemporal } = require('../../brain/temporal/index.cjs');
const { createFrontal } = require('../../brain/frontal/index.cjs');
const { createEmotionsBase } = require('../../brain/emotions_base/index.cjs');
const { createPersonality } = require('../../brain/personality/index.cjs');
const { createPineal } = require('../../brain/pineal/index.cjs');
const { makeLifeClockState } = require('../config/life-clock-config.cjs');
const { createDreamSeed, validateDreamSeed } = require('../brain/memory-lifecycle.cjs');
const { summarizeAffectForMemory } = require('../brain/affect-state-schema.cjs');
const { nowIso } = require('../util/time.cjs');
const { newId } = require('../util/ids.cjs');
const { statePath } = require('../util/fs-safe.cjs');
const { appendJsonlSync } = require('../util/jsonl.cjs');

function createChatRuntime(options = {}) {
  const sessionId = options.session_id || newId('chatsession');
  const startedAt = options.started_at || nowIso();

  return {
    session_id: sessionId,
    started_at: startedAt,
    thalamus: createThalamus({ persist_diagnostics: true }),
    hippocampus: createHippocampus({ persist_diagnostics: true }),
    amygdala: createAmygdala({ persist_diagnostics: true }),
    emotionsBase: createEmotionsBase({ persist_diagnostics: true }),
    personality: createPersonality({ persist_diagnostics: true }),
    pineal: createPineal({ persist_diagnostics: true }),
    temporal: createTemporal({ persist_diagnostics: true }),
    frontal: createFrontal({ persist_diagnostics: true })
  };
}

async function handleUserText(runtime, text) {
  const event = makeUserTextEvent(text, {
    trace_id: runtime.session_id,
    notes: 'terminal_chat'
  });

  const routeOutput = runtime.thalamus.routeEvent(event);
  const understandingOutput = runtime.temporal.understandEvent(event);
  const salienceOutput = runtime.amygdala.computeSalience(event);
  const affectDelta = runtime.emotionsBase.affectDeltaFromSalience(salienceOutput);
  const affectOutput = runtime.emotionsBase.applyAffectDelta(affectDelta);
  const affectSummary = summarizeAffectForMemory(affectOutput.payload.state);

  const memoryOutput = runtime.hippocampus.rememberEvent(event, {
    stream: 'short_term',
    type: text.toLowerCase().includes('remember') || text.toLowerCase().includes('identity') ? 'identity' : 'experience',
    tags: [
      'terminal_chat',
      'conversation',
      'user_text',
      `mood:${affectSummary.mood}`,
      ...affectSummary.dominant_emotions.map((emotion) => `emotion:${emotion.name}`)
    ],
    importance: salienceOutput.payload.salience.memory_importance_hint,
    affect: {
      valence: affectSummary.valence,
      arousal: affectSummary.arousal
    }
  });

  const memoryRecord = memoryOutput.payload.record;
  const personalityOutput = runtime.personality.updateFromMemory(memoryRecord);
  const personalitySummary = personalityOutput.payload.current;
  const identityOutput = runtime.pineal.updateFromMemory(memoryRecord, personalitySummary);

  const recallOutput = runtime.hippocampus.recall({
    text,
    streams: ['short_term', 'episodic', 'semantic', 'autobiographical'],
    limit: 3
  });

  const cognitionOutput = await runtime.frontal.runCognition({
    event,
    understanding: understandingOutput.payload,
    salience: salienceOutput.payload,
    affect: affectSummary,
    memories: recallOutput.payload.matches.map((match) => ({
      memory_id: match.record.id,
      summary: match.record.content.summary,
      tags: match.record.tags,
      affect: match.record.affect
    })),
    personality: personalityOutput.payload.current,
    identity: identityOutput.payload.current
  });

  return {
    event,
    routeOutput,
    salienceOutput,
    affectOutput,
    affectSummary,
    memoryOutput,
    personalityOutput,
    identityOutput,
    recallOutput,
    understandingOutput,
    cognitionOutput
  };
}

function handleSleep(runtime) {
  const currentAffect = runtime.emotionsBase.loadAffectState();
  const personalityState = runtime.personality.loadPersonalityState();
  const personalitySummary = runtime.personality.summarizePersonality(personalityState);
  const identityState = runtime.pineal.loadIdentityState();
  const identitySummary = runtime.pineal.summarizeIdentity(identityState);

  const consolidation = runtime.hippocampus.consolidateShortTerm({
    min_importance: 0.7
  });

  const recallOutput = runtime.hippocampus.recall({
    streams: ['short_term'],
    include_zero_score: true,
    limit: 12
  });

  const dayEvents = recallOutput.payload.matches.map((match) => ({
    memory_id: match.record.id,
    summary: match.record.content.summary,
    tags: match.record.tags,
    importance: match.record.importance,
    affect: match.record.affect
  }));

  const affectSummary = summarizeAffectForMemory(currentAffect);

  const dreamSeed = createDreamSeed({
    day_events: dayEvents,
    inner_thoughts: [
      {
        summary: identitySummary.continuity_summary,
        source: 'pineal_identity'
      },
      {
        summary: `Current hopes: ${personalitySummary.hopes.map((item) => item.name).join(', ') || 'still forming'}`,
        source: 'personality'
      }
    ],
    affect: {
      valence: affectSummary.valence,
      arousal: affectSummary.arousal,
      dominant_emotions: affectSummary.dominant_emotions.map((emotion) => emotion.name)
    },
    personality: {
      traits: Object.fromEntries(personalitySummary.top_traits.map((trait) => [trait.name, trait.value])),
      likes: personalitySummary.likes,
      dislikes: personalitySummary.dislikes,
      fears: personalitySummary.fears,
      hopes: personalitySummary.hopes,
      dreams: personalitySummary.dreams,
      values: personalitySummary.values
    },
    identity: {
      name: identitySummary.name,
      continuity_summary: identitySummary.continuity_summary
    },
    tags: ['sleep_cycle', runtime.session_id, `mood:${affectSummary.mood}`]
  });

  validateDreamSeed(dreamSeed);
  appendJsonlSync(statePath('dreams/dream-seeds.jsonl'), dreamSeed);

  runtime.emotionsBase.applyAffectDelta({
    core: {
      valence: currentAffect.core.valence * 0.5,
      arousal: Math.max(0, currentAffect.core.arousal - 0.35),
      dominance: currentAffect.core.dominance
    },
    emotions: {
      calm: 0.8,
      uncertainty: Math.max(0, currentAffect.emotions.uncertainty - 0.2),
      fear: Math.max(0, currentAffect.emotions.fear - 0.2),
      curiosity: currentAffect.emotions.curiosity
    },
    regulation: {
      sleep_pressure: 0,
      dream_pressure: dreamSeed.dream_pressure
    }
  });

  return {
    consolidation,
    dreamSeed,
    affectSummary,
    personalitySummary,
    identitySummary
  };
}

