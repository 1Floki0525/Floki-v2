'use strict';

/**
 * Floki-v2 model config.
 *
 * This file defines model boundaries only.
 * It does not call Ollama.
 * It does not call qwen3-vl during Stage 01.
 *
 * Critical policy:
 * - qwen3.5:4b may be used for cognition later.
 * - qwen3-vl:4b may be used for static PNG vision later.
 * - Vision thinking must remain false.
 * - Hidden reasoning must never be stored raw.
 */

const DEFAULT_OLLAMA_COGNITION_ENDPOINT = 'http://127.0.0.1:11434';
const DEFAULT_OLLAMA_VISION_ENDPOINT = 'http://127.0.0.1:11435';

const MODEL_CONFIG = Object.freeze({
stage: 'stage_07_affect_scaffold_no_cognition_calls',

  cognition: Object.freeze({
    provider: 'ollama',
    model: 'qwen3.5:4b',
    endpoint: process.env.FLOKI_COGNITION_ENDPOINT || DEFAULT_OLLAMA_COGNITION_ENDPOINT,
    allow_thinking: true,
    expose_hidden_reasoning: false,
    store_raw_hidden_reasoning: false,
    store_safe_reasoning_summary: true,
    timeout_ms: numberFromEnv('FLOKI_COGNITION_TIMEOUT_MS', 120000),
    temperature: numberFromEnv('FLOKI_COGNITION_TEMPERATURE', 0.45),
    top_p: numberFromEnv('FLOKI_COGNITION_TOP_P', 0.9),
    keep_alive: process.env.FLOKI_COGNITION_KEEP_ALIVE || '24h'
  }),

  vision: Object.freeze({
    provider: 'ollama',
    model: 'qwen3-vl:9b',
    endpoint: process.env.FLOKI_VISION_ENDPOINT || DEFAULT_OLLAMA_VISION_ENDPOINT,
    enabled_in_current_stage: false,
    allow_thinking: false,
    expose_hidden_reasoning: false,
    store_raw_hidden_reasoning: false,
    store_safe_reasoning_summary: false,
    reject_think_tags: true,
    timeout_ms: numberFromEnv('FLOKI_VISION_TIMEOUT_MS', 120000),
    temperature: numberFromEnv('FLOKI_VISION_TEMPERATURE', 0.1),
    top_p: numberFromEnv('FLOKI_VISION_TOP_P', 0.8),
    keep_alive: process.env.FLOKI_VISION_KEEP_ALIVE || '24h'
  }),

  forbidden: Object.freeze({
    minecraft_in_stage_01: true,
    mineflayer: true,
    pathfinding_libraries: true,
    rcon_body_control: true,
    desktop_automation: true,
    host_screenshot_vision: true,
    fake_success: true,
    raw_chain_of_thought_storage: true
  })
});

function numberFromEnv(name, fallback) {
  const raw = process.env[name];

  if (typeof raw === 'undefined' || raw === '') {
    return fallback;
  }

  const parsed = Number(raw);
  if (!Number.isFinite(parsed)) {
    throw new TypeError(`${name} must be a finite number`);
  }

  return parsed;
}

function validateEndpoint(endpoint, fieldName) {
  if (typeof endpoint !== 'string' || endpoint.trim() === '') {
    throw new TypeError(`${fieldName} must be a non-empty URL string`);
  }

  let parsed;
  try {
    parsed = new URL(endpoint);
  } catch (error) {
    throw new TypeError(`${fieldName} must be a valid URL: ${error.message}`);
  }

  if (!['http:', 'https:'].includes(parsed.protocol)) {
    throw new TypeError(`${fieldName} must use http or https`);
  }

  return true;
}

function validateModelConfig(config = MODEL_CONFIG) {
  if (config.cognition.model !== 'qwen3.5:4b') {
    throw new Error('cognition model must be qwen3.5:4b');
  }

  if (config.vision.model !== 'qwen3-vl:4b') {
    throw new Error('vision model must be qwen3-vl:4b');
  }

  validateEndpoint(config.cognition.endpoint, 'cognition.endpoint');
  validateEndpoint(config.vision.endpoint, 'vision.endpoint');

  if (config.cognition.expose_hidden_reasoning !== false) {
    throw new Error('cognition hidden reasoning must not be exposed');
  }

  if (config.cognition.store_raw_hidden_reasoning !== false) {
    throw new Error('cognition raw hidden reasoning must not be stored');
  }

  if (config.vision.allow_thinking !== false) {
    throw new Error('vision thinking must be false');
  }

  if (config.vision.reject_think_tags !== true) {
    throw new Error('vision outputs must reject think tags');
  }

  if (config.vision.enabled_in_current_stage !== false) {
    throw new Error('vision must not be enabled during Stage 01 foundation');
  }

  return true;
}

function getCognitionConfig() {
  validateModelConfig(MODEL_CONFIG);
  return MODEL_CONFIG.cognition;
}

function getVisionConfig() {
  validateModelConfig(MODEL_CONFIG);
  return MODEL_CONFIG.vision;
}

module.exports = {
  DEFAULT_OLLAMA_COGNITION_ENDPOINT,
  DEFAULT_OLLAMA_VISION_ENDPOINT,
  MODEL_CONFIG,
  numberFromEnv,
  validateEndpoint,
  validateModelConfig,
  getCognitionConfig,
  getVisionConfig
};
