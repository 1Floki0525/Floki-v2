'use strict';

/**
 * Floki-v2 affect state schema.
 *
 * Affect is fast-changing state.
 * Personality is slow-changing state.
 *
 * This file models affect without pretending it is full personhood.
 */

const { nowIso, assertIsoString } = require('../util/time.cjs');

const EMOTION_CHANNELS = Object.freeze([
  'joy',
  'sadness',
  'fear',
  'anger',
  'disgust',
  'surprise',
  'curiosity',
  'uncertainty',
  'hope',
  'trust',
  'calm',
  'loneliness',
  'attachment'
]);

const DEFAULT_AFFECT_STATE = Object.freeze({
  schema: 'floki-v2-affect-state-v1',
  updated_at: '1970-01-01T00:00:00.000Z',
  core: Object.freeze({
    valence: 0,
    arousal: 0,
    dominance: 0
  }),
  emotions: Object.freeze({
    joy: 0,
    sadness: 0,
    fear: 0,
    anger: 0,
    disgust: 0,
    surprise: 0,
    curiosity: 0,
    uncertainty: 0,
    hope: 0,
    trust: 0,
    calm: 0.5,
    loneliness: 0,
    attachment: 0
  }),
  mood: Object.freeze({
    label: 'neutral',
    stability: 0.5,
    momentum: 0
  }),
  regulation: Object.freeze({
    inhibition_bias: 0,
    approach_bias: 0,
    avoidance_bias: 0,
    sleep_pressure: 0,
    dream_pressure: 0
  }),
  provenance: Object.freeze({
    last_event_id: null,
    last_salience_output_id: null,
    safe_summary_only: true
  })
});

function cloneDefaultAffectState() {
  return JSON.parse(JSON.stringify(DEFAULT_AFFECT_STATE));
}

function assertPlainObject(value, fieldName) {
  if (value === null || typeof value !== 'object' || Array.isArray(value)) {
    throw new TypeError(`${fieldName} must be a plain object`);
  }
}

function clamp(value, min, max, fieldName) {
  const number = typeof value === 'number' ? value : 0;

  if (!Number.isFinite(number)) {
    throw new TypeError(`${fieldName} must be finite`);
  }

  return Math.min(max, Math.max(min, number));
}

function clampUnit(value, fieldName) {
  return clamp(value, 0, 1, fieldName);
}

function clampSigned(value, fieldName) {
  return clamp(value, -1, 1, fieldName);
}

function rejectUnsafeMarkers(value, fieldName = 'affect state') {
  const lower = JSON.stringify(value).toLowerCase();

  for (const marker of ['<think>', '</think>', 'chain_of_thought', 'hidden_reasoning', 'raw_reasoning', 'scratchpad']) {
    if (lower.includes(marker)) {
      throw new Error(`${fieldName} contains banned private-reasoning marker: ${marker}`);
    }
  }

  return true;
}

function normalizeAffectState(input = {}) {
  assertPlainObject(input, 'affect state input');

  const base = cloneDefaultAffectState();
  const now = input.updated_at || nowIso();

  assertIsoString(now, 'affect updated_at');

  const incomingCore = input.core && typeof input.core === 'object' ? input.core : {};
  const incomingEmotions = input.emotions && typeof input.emotions === 'object' ? input.emotions : {};
  const incomingMood = input.mood && typeof input.mood === 'object' ? input.mood : {};
  const incomingRegulation = input.regulation && typeof input.regulation === 'object' ? input.regulation : {};
  const incomingProvenance = input.provenance && typeof input.provenance === 'object' ? input.provenance : {};

  const state = {
    schema: 'floki-v2-affect-state-v1',
    updated_at: now,
    core: {
      valence: clampSigned(incomingCore.valence ?? base.core.valence, 'core.valence'),
      arousal: clampUnit(incomingCore.arousal ?? base.core.arousal, 'core.arousal'),
      dominance: clampSigned(incomingCore.dominance ?? base.core.dominance, 'core.dominance')
    },
    emotions: {},
    mood: {
      label: typeof incomingMood.label === 'string' && incomingMood.label.trim() ? incomingMood.label.trim() : base.mood.label,
      stability: clampUnit(incomingMood.stability ?? base.mood.stability, 'mood.stability'),
      momentum: clampSigned(incomingMood.momentum ?? base.mood.momentum, 'mood.momentum')
    },
    regulation: {
      inhibition_bias: clampUnit(incomingRegulation.inhibition_bias ?? base.regulation.inhibition_bias, 'regulation.inhibition_bias'),
      approach_bias: clampSigned(incomingRegulation.approach_bias ?? base.regulation.approach_bias, 'regulation.approach_bias'),
      avoidance_bias: clampUnit(incomingRegulation.avoidance_bias ?? base.regulation.avoidance_bias, 'regulation.avoidance_bias'),
      sleep_pressure: clampUnit(incomingRegulation.sleep_pressure ?? base.regulation.sleep_pressure, 'regulation.sleep_pressure'),
      dream_pressure: clampUnit(incomingRegulation.dream_pressure ?? base.regulation.dream_pressure, 'regulation.dream_pressure')
    },
    provenance: {
      last_event_id: typeof incomingProvenance.last_event_id === 'string' ? incomingProvenance.last_event_id : null,
      last_salience_output_id: typeof incomingProvenance.last_salience_output_id === 'string' ? incomingProvenance.last_salience_output_id : null,
      safe_summary_only: true
    }
  };

  for (const channel of EMOTION_CHANNELS) {
    state.emotions[channel] = clampUnit(incomingEmotions[channel] ?? base.emotions[channel] ?? 0, `emotions.${channel}`);
  }

  state.mood.label = deriveMoodLabel(state);
  validateAffectState(state);

  return state;
}

function validateAffectState(state) {
  assertPlainObject(state, 'affect state');

  if (state.schema !== 'floki-v2-affect-state-v1') {
    throw new Error(`invalid affect schema: ${state.schema}`);
  }

  assertIsoString(state.updated_at, 'affect updated_at');
  assertPlainObject(state.core, 'affect core');
  assertPlainObject(state.emotions, 'affect emotions');
  assertPlainObject(state.mood, 'affect mood');
  assertPlainObject(state.regulation, 'affect regulation');
  assertPlainObject(state.provenance, 'affect provenance');

  clampSigned(state.core.valence, 'core.valence');
  clampUnit(state.core.arousal, 'core.arousal');
  clampSigned(state.core.dominance, 'core.dominance');

  for (const channel of EMOTION_CHANNELS) {
    clampUnit(state.emotions[channel], `emotions.${channel}`);
  }

  if (state.provenance.safe_summary_only !== true) {
    throw new Error('affect provenance.safe_summary_only must be true');
  }

  rejectUnsafeMarkers(state);

  return true;
}

function deriveMoodLabel(state) {
  const core = state.core || {};
  const emotions = state.emotions || {};

  if ((emotions.fear || 0) >= 0.65) return 'afraid';
  if ((emotions.anger || 0) >= 0.65) return 'angry';
  if ((emotions.sadness || 0) >= 0.65) return 'sad';
  if ((emotions.curiosity || 0) >= 0.65) return 'curious';
  if ((emotions.hope || 0) >= 0.65) return 'hopeful';
  if ((emotions.trust || 0) >= 0.65 && core.valence > 0.2) return 'trusting';
  if ((emotions.calm || 0) >= 0.65 && core.arousal < 0.35) return 'calm';
  if (core.valence > 0.35) return 'positive';
  if (core.valence < -0.35) return 'negative';
  if (core.arousal > 0.7) return 'activated';

  return 'neutral';
}

function blendAffectState(previous, delta, options = {}) {
  const prior = normalizeAffectState(previous || {});
  const incoming = normalizeAffectState({
    ...prior,
    ...delta,
    core: {
      ...prior.core,
      ...(delta && delta.core ? delta.core : {})
    },
    emotions: {
      ...prior.emotions,
      ...(delta && delta.emotions ? delta.emotions : {})
    },
    mood: {
      ...prior.mood,
      ...(delta && delta.mood ? delta.mood : {})
    },
    regulation: {
      ...prior.regulation,
      ...(delta && delta.regulation ? delta.regulation : {})
    },
    provenance: {
      ...prior.provenance,
      ...(delta && delta.provenance ? delta.provenance : {})
    }
  });

  const alpha = clampUnit(options.alpha ?? 0.35, 'blend alpha');

  const blended = {
    ...prior,
    updated_at: nowIso(),
    core: {
      valence: round(blend(prior.core.valence, incoming.core.valence, alpha)),
      arousal: round(blend(prior.core.arousal, incoming.core.arousal, alpha)),
      dominance: round(blend(prior.core.dominance, incoming.core.dominance, alpha))
    },
    emotions: {},
    mood: {
      label: 'neutral',
      stability: round(blend(prior.mood.stability, incoming.mood.stability, alpha)),
      momentum: round(incoming.core.valence - prior.core.valence)
    },
    regulation: {
      inhibition_bias: round(blend(prior.regulation.inhibition_bias, incoming.regulation.inhibition_bias, alpha)),
      approach_bias: round(blend(prior.regulation.approach_bias, incoming.regulation.approach_bias, alpha)),
      avoidance_bias: round(blend(prior.regulation.avoidance_bias, incoming.regulation.avoidance_bias, alpha)),
      sleep_pressure: round(blend(prior.regulation.sleep_pressure, incoming.regulation.sleep_pressure, alpha)),
      dream_pressure: round(blend(prior.regulation.dream_pressure, incoming.regulation.dream_pressure, alpha))
    },
    provenance: {
      last_event_id: incoming.provenance.last_event_id || prior.provenance.last_event_id,
      last_salience_output_id: incoming.provenance.last_salience_output_id || prior.provenance.last_salience_output_id,
      safe_summary_only: true
    }
  };

  for (const channel of EMOTION_CHANNELS) {
    blended.emotions[channel] = round(blend(prior.emotions[channel], incoming.emotions[channel], alpha));
  }

  blended.mood.label = deriveMoodLabel(blended);
  validateAffectState(blended);

  return blended;
}

function blend(a, b, alpha) {
  return a + ((b - a) * alpha);
}

function round(value) {
  return Number(value.toFixed(4));
}

function summarizeAffectForMemory(state) {
  validateAffectState(state);

  return {
    valence: state.core.valence,
    arousal: state.core.arousal,
    dominance: state.core.dominance,
    mood: state.mood.label,
    dominant_emotions: dominantEmotions(state, 4)
  };
}

function dominantEmotions(state, limit = 3) {
  validateAffectState(state);

  return Object.entries(state.emotions)
    .sort((a, b) => b[1] - a[1])
    .filter(([, value]) => value > 0)
    .slice(0, limit)
    .map(([name, value]) => ({
      name,
      intensity: value
    }));
}

module.exports = {
  EMOTION_CHANNELS,
  DEFAULT_AFFECT_STATE,
  cloneDefaultAffectState,
  clamp,
  clampUnit,
  clampSigned,
  rejectUnsafeMarkers,
  normalizeAffectState,
  validateAffectState,
  deriveMoodLabel,
  blendAffectState,
  summarizeAffectForMemory,
  dominantEmotions
};
