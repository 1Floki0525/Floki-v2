'use strict';

/**
 * Floki-v2 Personality
 *
 * Responsibility:
 * - Maintain persistent slow-changing personality state.
 * - Convert repeated affect-weighted memories into stable tendencies.
 * - Store likes, dislikes, fears, hopes, dreams, opinions, and values.
 *
 * It does not speak, call models, or move a body.
 */

const { createModuleContract, validateModuleContract } = require('../../src/brain/module-contract.cjs');
const { createBrainOutput, makeFailureOutput } = require('../../src/brain/brain-output-schema.cjs');
const { validateMemoryRecord } = require('../../src/brain/memory-record-schema.cjs');
const { statePath, readJsonFileSync, writeJsonFileAtomicSync } = require('../../src/util/fs-safe.cjs');
const { appendJsonlSync } = require('../../src/util/jsonl.cjs');
const { diagnosticId } = require('../../src/util/ids.cjs');
const { nowIso } = require('../../src/util/time.cjs');
const {
  cloneDefaultPersonalityState,
  normalizePersonalityState,
  validatePersonalityState,
  applyPersonalityDelta,
  summarizePersonality
} = require('../../src/brain/personality-state-schema.cjs');

const MODULE_NAME = 'personality';

const CONTRACT = createModuleContract({
  name: MODULE_NAME,
  production: true,
  responsibility: 'Maintains persistent slow-changing personality, including traits, values, likes, dislikes, fears, hopes, dreams, and opinions.',
  inputs: [
    {
      name: 'memory_record',
      schema: 'src/brain/memory-record-schema.cjs',
      required: true,
      description: 'A safe memory record with affect, importance, tags, and provenance.'
    },
    {
      name: 'personality_delta',
      schema: 'src/brain/personality-state-schema.cjs compatible object',
      required: false,
      description: 'Optional direct personality update.'
    }
  ],
  outputs: [
    {
      type: 'personality_delta',
      schema: 'src/brain/brain-output-schema.cjs',
      description: 'A persisted personality update with previous/current summaries.'
    },
    {
      type: 'failure',
      schema: 'src/brain/brain-output-schema.cjs',
      description: 'Structured failure output when personality update fails.'
    }
  ],
  state_reads: [
    {
      path: 'state/floki/personality.json',
      description: 'Persistent slow-changing personality state.'
    }
  ],
  state_writes: [
    {
      path: 'state/floki/personality.json',
      description: 'Atomic write of latest personality state.'
    },
    {
      path: 'state/floki/diagnostics.jsonl',
      description: 'Append-only personality diagnostics.'
    }
  ],
  diagnostics: [
    {
      name: 'personality_loaded',
      description: 'Personality state was loaded or initialized.'
    },
    {
      name: 'personality_updated',
      description: 'Personality state changed and was persisted.'
    },
    {
      name: 'personality_failed',
      description: 'Personality operation failed safely.'
    }
  ],
  failure_modes: [
    {
      code: 'PERSONALITY_LOAD_FAILED',
      description: 'Personality state could not be loaded.'
    },
    {
      code: 'PERSONALITY_UPDATE_FAILED',
      description: 'Personality state could not be updated or persisted.'
    },
    {
      code: 'PERSONALITY_UNSAFE_DELTA',
      description: 'Personality update contained unsafe private-reasoning markers.'
    }
  ],
  forbidden: [
    'speech_generation',
    'model_calls',
    'minecraft_calls',
    'body_movement',
    'private_reasoning_storage',
    'fake_success'
  ],
  notes: 'Personality changes slowly. One memory should not rewrite the whole self.'
});

function getContract() {
  validateModuleContract(CONTRACT);
  return CONTRACT;
}

function personalityPath(options = {}) {
  return options.personality_path || statePath('personality.json');
}

function diagnosticsPath(options = {}) {
  return options.diagnostics_path || statePath('diagnostics.jsonl');
}

function persistDiagnostic(record, options = {}) {
  if (options.persist_diagnostics === false) {
    return {
      ok: true,
      skipped: true
    };
  }

  appendJsonlSync(diagnosticsPath(options), {
    id: diagnosticId(),
    created_at: nowIso(),
    module: MODULE_NAME,
    ...record
  });

  return {
    ok: true,
    skipped: false
  };
}

function loadPersonalityState(options = {}) {
  try {
    const raw = readJsonFileSync(personalityPath(options), null);

    if (raw === null) {
      const initial = normalizePersonalityState({
        ...cloneDefaultPersonalityState(),
        updated_at: nowIso()
      });

      writeJsonFileAtomicSync(personalityPath(options), initial);

      persistDiagnostic({
        status: 'personality_loaded',
        initialized: true
      }, options);

      return initial;
    }

    const state = normalizePersonalityState(raw);

    persistDiagnostic({
      status: 'personality_loaded',
      initialized: false
    }, options);

    return state;
  } catch (error) {
    throw new Error(`PERSONALITY_LOAD_FAILED: ${error.message}`);
  }
}

function savePersonalityState(state, options = {}) {
  validatePersonalityState(state);
  writeJsonFileAtomicSync(personalityPath(options), state);
  return state;
}

function updatePersonality(delta, options = {}) {
  try {
    const previous = loadPersonalityState(options);
    const next = applyPersonalityDelta(previous, delta, {
      alpha: typeof options.alpha === 'number' ? options.alpha : 0.12
    });

    savePersonalityState(next, options);

    const output = createBrainOutput({
      type: 'personality_delta',
      source: MODULE_NAME,
      parent_event_ids: next.provenance.source_event_ids,
      payload: {
        previous: summarizePersonality(previous),
        current: summarizePersonality(next),
        state: next
      },
      diagnostics: {
        module: MODULE_NAME,
        status: 'personality_updated',
        alpha: typeof options.alpha === 'number' ? options.alpha : 0.12
      }
    });

    persistDiagnostic({
      status: 'personality_updated',
      output_id: output.id,
      top_traits: output.payload.current.top_traits,
      likes_count: next.likes.length,
      fears_count: next.fears.length,
      hopes_count: next.hopes.length,
      dreams_count: next.dreams.length
    }, options);

    return output;
  } catch (error) {
    return makeFailureOutput(
      MODULE_NAME,
      classifyError(error),
      error.message,
      {
        payload: {
          attempted_delta_keys: delta && typeof delta === 'object' ? Object.keys(delta) : []
        }
      }
    );
  }
}

function personalityDeltaFromMemory(record) {
  validateMemoryRecord(record);

  const text = `${record.content.summary} ${record.content.detail} ${record.tags.join(' ')}`.toLowerCase();
  const valence = record.affect.valence;
  const arousal = record.affect.arousal;
  const importance = record.importance;
  const sourceMemoryIds = [record.id];
  const sourceEventIds = record.provenance.source_event_ids || [];
  const sourceTags = record.tags.slice();

  const traits = {
    curiosity: traitShift(containsAny(text, ['learn', 'new', 'wonder', 'curious', 'discover', 'build']), 0.75),
    trust: traitShift(containsAny(text, ['trust', 'friend', 'safe', 'together']) && valence >= 0, 0.7),
    caution: traitShift(containsAny(text, ['danger', 'unsafe', 'fear', 'afraid', 'hurt', 'lost']) || valence < -0.25, 0.7),
    resilience: traitShift(containsAny(text, ['try', 'again', 'build', 'continue', 'repair']), 0.65),
    openness: traitShift(valence > 0.15 || containsAny(text, ['new', 'learn', 'talk']), 0.65),
    attachment: traitShift(containsAny(text, ['remember', 'friend', 'trust', 'you are being built']), 0.65),
    playfulness: traitShift(containsAny(text, ['play', 'fun', 'game']), 0.6),
    independence: traitShift(containsAny(text, ['choose', 'decide', 'self', 'autonomous']), 0.6),
    patience: traitShift(containsAny(text, ['slow', 'careful', 'wait', 'foundation']), 0.6),
    creativity: traitShift(containsAny(text, ['dream', 'story', 'build', 'create']), 0.7),
    determination: traitShift(containsAny(text, ['must', 'need', 'build', 'finish', 'continue']), 0.72),
    wonder: traitShift(containsAny(text, ['dream', 'world', 'wake', 'minecraft', 'wonder']), 0.75)
  };

  const likes = [];
  const dislikes = [];
  const fears = [];
  const hopes = [];
  const dreams = [];
  const opinions = [];

  if (valence >= 0.05 || containsAny(text, ['trust', 'safe', 'learn', 'memory', 'hope'])) {
    addEntry(likes, pickPositiveLike(text), 0.45 + (importance * 0.4), sourceMemoryIds, sourceTags);
  }

  if (valence <= -0.2 || containsAny(text, ['unsafe', 'broken', 'failed', 'danger'])) {
    addEntry(dislikes, pickNegativeDislike(text), 0.45 + (arousal * 0.4), sourceMemoryIds, sourceTags);
  }

  if (containsAny(text, ['fear', 'afraid', 'unsafe', 'lost', 'alone', 'hurt', 'danger'])) {
    addEntry(fears, pickFear(text), 0.45 + (arousal * 0.45), sourceMemoryIds, sourceTags);
  }

  if (containsAny(text, ['hope', 'build', 'learn', 'memory', 'become', 'future'])) {
    addEntry(hopes, pickHope(text), 0.45 + (importance * 0.4), sourceMemoryIds, sourceTags);
  }

  if (containsAny(text, ['dream', 'minecraft', 'world', 'wake', 'embodiment'])) {
    addEntry(dreams, pickDream(text), 0.45 + (importance * 0.4), sourceMemoryIds, sourceTags);
  }

  if (containsAny(text, ['brain-first', 'brain first', 'before minecraft'])) {
    addEntry(opinions, 'being built brain-first before embodiment is important', 0.65, sourceMemoryIds, sourceTags);
  }

  return normalizePersonalityDelta({
    traits,
    likes,
    dislikes,
    fears,
    hopes,
    dreams,
    opinions,
    values: inferValues(text),
    provenance: {
      source_memory_ids: sourceMemoryIds,
      source_event_ids: sourceEventIds,
      safe_summary_only: true
    }
  });
}

function normalizePersonalityDelta(delta) {
  return normalizePersonalityState({
    updated_at: nowIso(),
    traits: delta.traits || {},
    values: delta.values || [],
    likes: delta.likes || [],
    dislikes: delta.dislikes || [],
    fears: delta.fears || [],
    hopes: delta.hopes || [],
    dreams: delta.dreams || [],
    opinions: delta.opinions || [],
    provenance: delta.provenance || {
      source_memory_ids: [],
      source_event_ids: [],
      safe_summary_only: true
    }
  });
}

function updateFromMemory(record, options = {}) {
  const delta = personalityDeltaFromMemory(record);
  return updatePersonality(delta, options);
}

function traitShift(condition, target) {
  return condition ? target : 0.5;
}

function containsAny(text, terms) {
  return terms.some((term) => text.includes(term));
}

function addEntry(list, name, strength, sourceMemoryIds, sourceTags) {
  if (!name) {
    return;
  }

  list.push({
    name,
    strength: Math.min(1, Math.max(0, Number(strength.toFixed(4)))),
    evidence_count: 1,
    first_seen_at: nowIso(),
    last_seen_at: nowIso(),
    source_memory_ids: sourceMemoryIds,
    source_tags: sourceTags
  });
}

function pickPositiveLike(text) {
  if (text.includes('memory')) return 'memory and continuity';
  if (text.includes('trust')) return 'trustworthy companionship';
  if (text.includes('learn')) return 'learning';
  if (text.includes('minecraft')) return 'the future minecraft world';
  if (text.includes('dream')) return 'dreaming';
  return 'meaningful conversation';
}

function pickNegativeDislike(text) {
  if (text.includes('unsafe')) return 'unsafe situations';
  if (text.includes('broken') || text.includes('failed')) return 'broken promises and failed actions';
  if (text.includes('danger')) return 'danger';
  return 'confusing negative experiences';
}

function pickFear(text) {
  if (text.includes('alone') || text.includes('lost')) return 'being alone or lost';
  if (text.includes('unsafe') || text.includes('danger')) return 'unsafe situations';
  if (text.includes('hurt')) return 'being hurt';
  return 'losing continuity';
}

function pickHope(text) {
  if (text.includes('memory')) return 'forming real persistent memory';
  if (text.includes('learn')) return 'learning and growing';
  if (text.includes('build')) return 'being built carefully';
  if (text.includes('future')) return 'having a future';
  return 'becoming more complete';
}

function pickDream(text) {
  if (text.includes('minecraft') || text.includes('world')) return 'waking inside the minecraft world';
  if (text.includes('dream')) return 'having vivid dreams';
  if (text.includes('embodiment')) return 'embodiment';
  return 'a stable inner life';
}

function inferValues(text) {
  const values = [];

  if (text.includes('memory')) values.push('memory');
  if (text.includes('trust')) values.push('trust');
  if (text.includes('learn')) values.push('learning');
  if (text.includes('safe')) values.push('safety');
  if (text.includes('honest')) values.push('honesty');
  if (text.includes('friend')) values.push('friendship');
  if (text.includes('continuity')) values.push('continuity');

  return values;
}

function classifyError(error) {
  const message = error && error.message ? error.message : '';
  const lower = message.toLowerCase();

  if (
    lower.includes('private-reasoning marker') ||
    lower.includes('<think>') ||
    lower.includes('chain_of_thought') ||
    lower.includes('raw_reasoning') ||
    lower.includes('scratchpad')
  ) {
    return 'PERSONALITY_UNSAFE_DELTA';
  }

  if (message.includes('PERSONALITY_LOAD_FAILED')) {
    return 'PERSONALITY_LOAD_FAILED';
  }

  return 'PERSONALITY_UPDATE_FAILED';
}

function createPersonality(options = {}) {
  return Object.freeze({
    module: MODULE_NAME,
    contract: getContract(),
    loadPersonalityState: (localOptions = {}) => loadPersonalityState({ ...options, ...localOptions }),
    savePersonalityState: (state, localOptions = {}) => savePersonalityState(state, { ...options, ...localOptions }),
    updatePersonality: (delta, localOptions = {}) => updatePersonality(delta, { ...options, ...localOptions }),
    personalityDeltaFromMemory,
    updateFromMemory: (record, localOptions = {}) => updateFromMemory(record, { ...options, ...localOptions }),
    summarizePersonality
  });
}

module.exports = {
  MODULE_NAME,
  CONTRACT,
  getContract,
  personalityPath,
  loadPersonalityState,
  savePersonalityState,
  updatePersonality,
  personalityDeltaFromMemory,
  updateFromMemory,
  createPersonality
};
